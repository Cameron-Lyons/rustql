query ok
SELECT slt_ea_users.name, slt_ea_orders.amount
FROM slt_ea_users
JOIN slt_ea_orders ON slt_ea_users.id = slt_ea_orders.user_id
WHERE slt_ea_orders.amount >= 10.0
ORDER BY slt_ea_orders.id;
