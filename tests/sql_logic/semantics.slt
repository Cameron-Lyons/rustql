# focused semantic regressions
statement ok
CREATE TABLE slt_sem_values (id INTEGER, val INTEGER);

statement ok
INSERT INTO slt_sem_values VALUES (1, 10), (2, NULL), (3, 20);

query exact
SELECT id FROM slt_sem_values WHERE val IS DISTINCT FROM 10 ORDER BY id;
----
id
2
3

query exact
SELECT id FROM slt_sem_values WHERE val IS NOT DISTINCT FROM NULL ORDER BY id;
----
id
2

