statement ok
CREATE TABLE slt_sem_orders (id INTEGER, value INTEGER);

statement ok
INSERT INTO slt_sem_orders VALUES (1, 5), (2, 15), (3, 25);

query exact
SELECT id FROM slt_sem_orders
WHERE value > (SELECT AVG(value) FROM slt_sem_orders)
ORDER BY id;
----
id
3
