# basic data setup
statement ok
CREATE TABLE slt_users (id INTEGER, name TEXT, age INTEGER);

statement ok
INSERT INTO slt_users VALUES (1, 'Alice', 30), (2, 'Bob', 25), (3, 'Cara', 40);

query ok
SELECT name FROM slt_users WHERE age >= 30 ORDER BY name;
----
Alice
Cara

query ok
EXPLAIN ANALYZE SELECT * FROM slt_users WHERE age > 20;
----
Query Plan
Execution Time
Actual Rows

statement ok
CREATE TABLE slt_orders (id INTEGER, user_id INTEGER, amount FLOAT);

statement ok
INSERT INTO slt_orders VALUES (1, 1, 10.0), (2, 2, 20.0), (3, 1, 5.0);

query ok
SELECT slt_users.name, slt_orders.amount
FROM slt_users
JOIN slt_orders ON slt_users.id = slt_orders.user_id
ORDER BY slt_orders.id;
----
Alice
Bob
